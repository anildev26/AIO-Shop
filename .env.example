# Database (Neon.tech - free PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
AUTH_SECRET="your-random-secret-min-32-chars"   # generate: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# Site password gate (set this to any string you use as your site password)
SITE_PASSWORD_HASH="your-site-password"

# Cloudinary (free tier)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
